# Veylify — Ortam Değişkenleri (örnek)
# Bu dosyayı `.env.local` olarak kopyalayıp gerçek değerleri girin.
# .env.local git'e GİRMEZ — gizli anahtarları buraya YAZMAYIN.
#
# ÖNEMLİ: Veylify çekirdeği (kimlik doğrulama + veritabanı) kendi kalıcı
# JSON DB'si ve cookie-oturumu ile çalışır — canlıya çıkmak için ZORUNLU
# hiçbir dış anahtar YOKTUR. Aşağıdakiler yalnızca opsiyonel entegrasyonlar
# içindir; boş bırakılırsa ilgili özellik devre dışı kalır, uygulama çalışır.

# --- Uygulama ---
# Public site kökü (canonical/sitemap/OG için). Prod'da gerçek alan adı.
NEXT_PUBLIC_SITE_URL=https://veylify.com

# --- Opsiyonel: E-posta gönderimi (iletişim formu / uyarı e-postaları) ---
# Boşsa e-posta "kuyruğa alındı" olarak loglanır, gönderim yapılmaz.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Veylify <destek@veylify.com>

# --- Opsiyonel: Webhook imzalama sırrı (giden webhook HMAC) ---
VEYLIFY_WEBHOOK_SECRET=

# --- Opsiyonel: Hata/analitik (kendi anahtarınız) ---
# SENTRY_DSN=
# NEXT_PUBLIC_ANALYTICS_ID=
