# Veylify — Ortam Değişkenleri (örnek)
# Bu dosyayı `.env.local` olarak kopyalayıp gerçek değerleri girin.
# .env.local git'e GİRMEZ — gizli anahtarları buraya YAZMAYIN.
#
# ÖNEMLİ: Veylify çekirdeği (kimlik doğrulama + veritabanı) kendi kalıcı
# JSON DB'si ve cookie-oturumu ile çalışır — canlıya çıkmak için ZORUNLU
# hiçbir dış anahtar YOKTUR. Aşağıdakiler yalnızca opsiyonel entegrasyonlar
# içindir; boş bırakılırsa ilgili özellik devre dışı kalır, uygulama çalışır.

# --- Uygulama ---
# Public site kökü (canonical/sitemap/OG için). Prod'da gerçek alan adı.
NEXT_PUBLIC_SITE_URL=https://veylify.com

# --- E-posta gönderimi (SMTP — hoşgeldin, davet, askıya, digest mailleri) ---
# Sıfır-bağımlılık SMTP istemcisi (src/lib/specter/mail.ts). Boşsa mailler
# GÖNDERİLMEZ (konsola loglanır) — uygulama yine çalışır. Canlıda gerçek
# gönderim için doldur (Gmail App Password, Amazon SES SMTP, Resend SMTP…):
#   SMTP_HOST=email-smtp.eu-central-1.amazonaws.com   (SES örneği)
#   SMTP_PORT=587    (STARTTLS)  ya da  465 (implicit TLS → SMTP_SECURE=1)
#   SMTP_USER / SMTP_PASS = sağlayıcı SMTP kimlik bilgileri
#   SMTP_FROM = doğrulanmış gönderen (SPF/DKIM ayarlı domain)
# Test: /panel/admin (staff) → veya POST /api/admin {action:"mailTest"}.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Veylify <destek@veylify.com>
# SMTP_SECURE=1   # yalnız port 465 (implicit TLS) kullanıyorsan

# --- Platform admin (staff) allowlist — /panel/admin erişimi ---
# Virgülle ayrılmış e-postalar. Boşsa güvenli varsayılan (kurucu + demo) geçerli.
# Yalnız buradaki hesaplar Yönetici Konsolu'nu görür ve /api/admin işlemlerini yapar.
VEYLIFY_ADMIN_EMAILS=

# --- Opsiyonel: Webhook imzalama sırrı (giden webhook HMAC) ---
VEYLIFY_WEBHOOK_SECRET=

# --- SADECE TEST/GELİŞTİRME: yerel webhook alıcısına izin (SSRF istisnası) ---
# 1 yapılırsa localhost/iç-IP webhook URL'leri kabul edilir (uçtan-uca test için).
# PRODUCTION'DA ASLA SET ETME — SSRF riski. Varsayılan: kapalı.
# VEYLIFY_ALLOW_LOCAL_WEBHOOK=

# --- Opsiyonel: Hata/analitik (kendi anahtarınız) ---
# SENTRY_DSN=
# NEXT_PUBLIC_ANALYTICS_ID=

# --- Clerk kimlik doğrulama (production) ---
# Gerçek anahtarları buraya YAZMA — .env.local'a koy (git'e girmez).
# Clerk dashboard → API Keys. Production key yalnız izinli domain'de çalışır.
#
# ⚠️ CLERK'İ AÇMAK İÇİN VEYLIFY_CLERK=1 ŞART. Bu değişken yoksa (veya 1 değilse)
# uygulama Clerk'i HİÇ kullanmaz, kendi cookie-auth formuna düşer → Google
# girişi çalışmaz. Clerk (Google OAuth) istiyorsan bunu 1 yap + aşağıdaki
# publishable/secret key'leri gir + Vercel'e de aynı env'i ekle.
VEYLIFY_CLERK=1
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_veya_pk_live_...
CLERK_SECRET_KEY=sk_test_veya_sk_live_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/signup
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/panel
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/panel

# --- Google Analytics ---
# GA ölçüm kimliği layout.tsx'te sabit (G-35MZVLZKX2). Değiştirmek için orayı düzenle.

# --- Supabase (kalıcı DB) ---
# Vercel read-only fs → tüm state Supabase jsonb blobunda tutulur.
# Supabase Dashboard → Project Settings → API. service_role key (SUNUCU ONLY).
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=sb_secret_...
