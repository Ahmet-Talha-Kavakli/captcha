{
  "name": "@veylify/node",
  "version": "1.0.0",
  "description": "Official Veylify SDK for Node.js — server-side siteverify and webhook signature verification for ghost-font CAPTCHA / AI-bot protection.",
  "license": "MIT",
  "author": "Veylify",
  "homepage": "https://veylify.com/docs/sdk/node",
  "repository": {
